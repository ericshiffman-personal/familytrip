# ── Claude AI ─────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Unsplash ───────────────────────────────────────────────────────────────────
# Get your free key at https://unsplash.com/developers → "New Application"
# Used for destination hero photos (server-side only — never sent to browser)
# Without this key the homepage shows a navy gradient instead of a photo.
# Unsplash free tier: 50 req/hour. Next.js caches responses for 24h so you'll
# stay well within limits even with regular traffic.
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ── Google Places API (New) ────────────────────────────────────────────────────
# Get your key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "Places API (New)" — NOT the legacy Places API
# Restrict key to: Places API (New) + your domain (recommended)
# Used server-side only for hotel photo enrichment. Never use NEXT_PUBLIC_ prefix.
# Free tier: 1,000 photo requests/month. The app caps usage at 900 by default.
# To change the cap, set GOOGLE_PLACES_PHOTO_LIMIT to any number under 1,000.
# Monitor usage: https://console.cloud.google.com/apis/api/places_backend.googleapis.com/metrics
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Optional — override the default 900-request monthly cap
# GOOGLE_PLACES_PHOTO_LIMIT=900
